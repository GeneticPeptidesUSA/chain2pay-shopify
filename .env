# ----------------------------------------------------------------
# Chain2Pay Shopify Payment App — Environment Variables
# Copy this file to .env and fill in every value before starting.
# ----------------------------------------------------------------

# Your Shopify app credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# Offline access token for rushpeptides.myshopify.com
# Obtained after installing the app on the store
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Your store's myshopify domain (used for Admin API calls — do not change)
SHOPIFY_STORE_DOMAIN=rushpeptides.myshopify.com

# Your public-facing storefront domain (used for customer redirects)
STORE_CUSTOMER_DOMAIN=geneticpeptidesusa.com

# Your crypto wallet address for Chain2Pay
WALLET_ADDRESS=0xf3Eb80753D75B226F66c2e9C038a732868056462

# The public URL where this server is deployed (no trailing slash)
# e.g. https://chain2pay-rushpeptides.up.railway.app
APP_URL=https://your-deployed-app-url.com

# Server port (Railway/Render/Heroku set this automatically)
PORT=3000
